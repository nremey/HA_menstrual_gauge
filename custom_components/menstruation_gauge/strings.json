{
  "title": "Menstruation Gauge",
  "config": {
    "step": {
      "user": {
        "title": "Menstruation Gauge",
        "description": "Track menstrual cycles and get forecast predictions. No configuration needed - just click submit to enable."
      }
    }
  },
  "services": {
    "add_cycle_start": {
      "name": "Add cycle start",
      "description": "Add one cycle start day.",
      "fields": {
        "date": {
          "name": "Date",
          "description": "Date in YYYY-MM-DD format."
        }
      }
    },
    "remove_cycle_start": {
      "name": "Remove cycle start",
      "description": "Remove one cycle start day.",
      "fields": {
        "date": {
          "name": "Date",
          "description": "Date in YYYY-MM-DD format."
        }
      }
    },
    "set_history": {
      "name": "Set full history",
      "description": "Replace the whole cycle-start history list.",
      "fields": {
        "dates": {
          "name": "Dates",
          "description": "List of YYYY-MM-DD dates."
        }
      }
    },
    "set_period_duration": {
      "name": "Set period duration",
      "description": "Set expected period duration in days.",
      "fields": {
        "days": {
          "name": "Days",
          "description": "Expected period duration, 1-14."
        }
      }
    }
  }
}
